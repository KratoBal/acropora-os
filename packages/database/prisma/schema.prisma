generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  SALES
  WAREHOUSE
  SERVICE
  VIEWER
}

enum ProductType {
  PHYSICAL
  SERVICE
  LIVESTOCK
}

enum ProductMirrorState {
  ACTIVE
  MISSING
  CONFLICT
}

enum UnasProductSyncKind {
  FULL
  INCREMENTAL
}

enum UnasProductSyncRunStatus {
  PENDING
  RUNNING
  APPLIED
  FAILED
}

enum UnasOrderSyncRunStatus {
  PENDING
  RUNNING
  APPLIED
  FAILED
}

enum UnasCustomerSyncRunStatus {
  PENDING
  RUNNING
  APPLIED
  FAILED
}

enum NavInvoiceSyncRunStatus {
  PENDING
  RUNNING
  APPLIED
  FAILED
}

/// A NAV-tól letöltött belföldi beszállítói (bejövő) számla állapota a
/// bevételezési folyamatban: NEW - csak a digest ismert; DATA_FETCHED - a
/// teljes számla-XML lekérve és feldolgozva, bevételezhető; RECEIVED - már
/// bevételezve, a purchaseInvoiceId mutat a létrejött PurchaseInvoice-ra;
/// ERROR - a queryInvoiceData vagy a feldolgozás sikertelen volt, újra
/// próbálható.
enum NavIncomingInvoiceStatus {
  NEW
  DATA_FETCHED
  RECEIVED
  ERROR
}

enum StockMovementType {
  PURCHASE_RECEIPT
  SALE
  TRANSFER
  ADJUSTMENT
  RESERVATION
  RESERVATION_RELEASE
  RETURN_IN
  RETURN_OUT
  DAMAGE
  SCRAP
  OPENING_BALANCE
}

enum StockMovementStatus {
  DRAFT
  POSTED
  REVERSED
}

/// DRAFT: az Excel sablon kiment, számlálásra vár.
/// UPLOADED: a leltározott mennyiségek visszatöltve, korrekcióra várnak.
/// CORRECTED: a korrekció lefutott (StockItem frissült, UNAS push megtörtént).
enum InventoryCountStatus {
  DRAFT
  UPLOADED
  CORRECTED
}

/// Soronkénti UNAS setStock push kimenetele a korrekció során.
enum InventoryCountLineSyncStatus {
  PENDING
  OK
  FAILED
}

/// A pénztári (POS) eladás kiegyenlítésének módja.
enum PosPaymentMethod {
  CASH
  CARD
  TRANSFER
}

/// Soronkénti UNAS setStock push kimenetele egy POS eladás után.
enum SalesOrderLineSyncStatus {
  PENDING
  OK
  FAILED
}

enum PurchaseOrderStatus {
  DRAFT
  APPROVED
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
  CLOSED
}

enum GoodsReceiptStatus {
  DRAFT
  POSTED
  CANCELLED
}

/// Honnan származik a beérkezett számla: EU-s beszállítói számla kézi
/// rögzítése, belföldi számla kézi rögzítése (pl. ha a NAV-lekérdezés nem
/// elérhető), vagy belföldi számla a NAV Online Számla lekérdezéséből
/// előtöltve. A HU_NAV forrás egyelőre csak a séma szintjén létezik, a
/// hozzá tartozó lekérdezés-integráció külön munkacsomag.
enum PurchaseInvoiceSource {
  EU
  HU_MANUAL
  HU_NAV
}

enum PurchaseInvoiceStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum SalesOrderStatus {
  DRAFT
  PENDING
  CONFIRMED
  PICKING
  PACKED
  SHIPPED
  COMPLETED
  CANCELLED
  ON_HOLD
}

enum SalesChannel {
  UNAS
  POS
  MANUAL
  SERVICE
  API
}

enum CustomerType {
  PERSON
  COMPANY
}

enum AddressType {
  BILLING
  SHIPPING
  OTHER
}

enum ServiceJobStatus {
  NEW
  TRIAGED
  SCHEDULED
  IN_PROGRESS
  WAITING_FOR_PARTS
  WAITING_FOR_CUSTOMER
  COMPLETED
  CANCELLED
}

enum AquariumOwnershipType {
  OWN
  STORE
  CUSTOMER
}

enum ExternalSystem {
  UNAS
  SZAMLAZZ_HU
  OTHER
}

enum SyncStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  RETRYABLE_ERROR
  PERMANENT_ERROR
}

enum CatalogChannel {
  UNAS
}

enum ProductRelationType {
  ACCESSORY
  CROSS_SELL
  SIMILAR
  UP_SELL
}

enum CatalogImportProvider {
  UNAS
}

enum CatalogImportStatus {
  STAGED
  VALIDATED
  APPROVED
  APPLIED
  STALE
}

enum BrandResolutionReviewStatus {
  PENDING
  ACCEPTED
  NO_BRAND
}

enum CatalogImportEntityType {
  PRODUCT
  CATEGORY
  BRAND
}

enum CatalogImportRowStatus {
  VALID
  INVALID
}

enum UnasCredentialMode {
  ENV_FALLBACK
  DATABASE
  DISABLED
}

enum UnasVerificationStatus {
  NEVER
  SUCCESS
  FAILED
  INDETERMINATE
}

enum SzamlazzCredentialMode {
  ENV_FALLBACK
  DATABASE
  DISABLED
}

enum SzamlazzVerificationStatus {
  NEVER
  SUCCESS
  FAILED
  INDETERMINATE
}

enum InvoiceDirection {
  INBOUND
  OUTBOUND
}

enum InvoiceDocumentType {
  INVOICE
  ADVANCE_INVOICE
  FINAL_INVOICE
  STORNO
  CORRECTION
  PROFORMA
}

/// Az adott Invoice-sor rögzítésének eredeti adatforrása. A NAV itt csak
/// egyeztetési/import célból jelenhet meg (lásd ADR-005) - a napi
/// Számlázz.hu <-> NAV egyeztetés eredményeként keletkező eltérés-jelzés
/// külön, még nem modellezett entitás lesz (M9 munka).
enum InvoiceSource {
  SZAMLAZZ
  NAV
  MANUAL
  IMPORT
}

enum InvoiceSyncStatus {
  PENDING
  RECEIVED
  ERROR
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  displayName       String
  firstName         String    @default("")
  lastName          String    @default("")
  passwordHash      String?
  passwordUpdatedAt DateTime?
  role              UserRole
  isActive          Boolean   @default(true)
  avatarUrl         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  sessions               Session[]
  auditLogs              AuditLog[]
  domainEvents           DomainEvent[]
  stockMovements         StockMovement[]
  startedInventoryCounts InventoryCount[]
  posSales               SalesOrder[]
  createdPurchaseInvoices PurchaseInvoice[]
  unasCredentialsUpdated UnasConnectionSetting[] @relation("UnasCredentialUpdatedBy")
  szamlazzCredentialsUpdated SzamlazzConnectionSetting[] @relation("SzamlazzCredentialUpdatedBy")

  @@index([role, isActive])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Product {
  id              String              @id @default(cuid())
  name            String
  description     String?
  type            ProductType         @default(PHYSICAL)
  brandId         String?
  /// @deprecated Compatibility pointer. ProductCategory is the category source of truth.
  categoryId      String?
  isActive        Boolean             @default(true)
  archivedAt      DateTime?
  mirrorSource    ExternalSystem?
  mirrorState     ProductMirrorState?
  sourceCreatedAt DateTime?
  sourceUpdatedAt DateTime?
  lastSyncedAt    DateTime?
  missingSince    DateTime?
  rawSourceHash   String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  brand           Brand?               @relation(fields: [brandId], references: [id], onDelete: SetNull)
  legacyCategory  Category?            @relation("LegacyProductCategory", fields: [categoryId], references: [id], onDelete: SetNull)
  categories      ProductCategory[]
  variants        ProductVariant[]
  channelListings ChannelListing[]
  images          ProductImage[]
  sourceRelations ProductRelation[]    @relation("ProductRelationSource")
  targetRelations ProductRelation[]    @relation("ProductRelationTarget")
  unasSnapshot    UnasProductSnapshot?

  @@index([brandId])
  @@index([categoryId])
  @@index([type, isActive])
  @@index([mirrorSource, mirrorState])
  @@index([missingSince])
}

model ProductVariant {
  id                     String   @id @default(cuid())
  productId              String
  sku                    String   @unique
  name                   String?
  unit                   String   @default("db")
  vatRate                Decimal? @db.Decimal(5, 2)
  manufacturerPartNumber String?
  secondaryUnit          String?
  secondaryUnitFactor    Decimal? @db.Decimal(19, 6)
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  product             Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  barcodes            ProductBarcode[]
  supplierProducts    SupplierProduct[]
  stockItems          StockItem[]
  movementLines       StockMovementLine[]
  salesOrderLines     SalesOrderLine[]
  purchaseLines       PurchaseOrderLine[]
  receiptLines        GoodsReceiptLine[]
  purchaseInvoiceLines PurchaseInvoiceLine[]
  extension           ProductExtension?
  inventoryCountLines InventoryCountLine[]

  @@index([productId, isActive])
}

model Brand {
  id             String       @id @default(cuid())
  name           String
  normalizedName String       @unique
  slug           String       @unique
  description    String?
  websiteUrl     String?
  logoUrl        String?
  isActive       Boolean      @default(true)
  archivedAt     DateTime?
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  products       Product[]
  aliases        BrandAlias[]

  @@index([isActive, name])
}

model BrandAlias {
  id               String   @id @default(cuid())
  brandId          String
  alias            String
  normalizedAlias  String   @unique
  source           String   @default("MANUAL")
  sourceExternalId String?
  isPreferred      Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  brand            Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId, source])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent            Category?         @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children          Category[]        @relation("CategoryTree")
  legacyProducts    Product[]         @relation("LegacyProductCategory")
  productCategories ProductCategory[]

  @@index([parentId])
}

model ProductCategory {
  id         String   @id @default(cuid())
  productId  String
  categoryId String
  isPrimary  Boolean  @default(false)
  sortOrder  Int?
  source     String?
  createdAt  DateTime @default(now())

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([productId, categoryId])
  @@index([categoryId, productId])
  @@index([productId, isPrimary])
}

model ChannelListing {
  id               String         @id @default(cuid())
  productId        String
  channel          CatalogChannel
  externalStatus   String?
  isPublished      Boolean        @default(false)
  slug             String?
  productUrl       String?
  seoTitle         String?
  seoDescription   String?
  seoKeywords      String?
  seoRobots        String?
  backorderAllowed Boolean        @default(false)
  sourceCreatedAt  DateTime?
  sourceUpdatedAt  DateTime?
  metadata         Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, channel])
  @@index([channel, isPublished])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  sortOrder Int      @default(0)
  altText   String?
  title     String?
  fileName  String?
  source    String
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, url])
  @@index([productId, sortOrder])
}

model ProductRelation {
  id              String              @id @default(cuid())
  sourceProductId String
  targetProductId String
  relationType    ProductRelationType
  sortOrder       Int?
  source          String?

  sourceProduct Product @relation("ProductRelationSource", fields: [sourceProductId], references: [id], onDelete: Cascade)
  targetProduct Product @relation("ProductRelationTarget", fields: [targetProductId], references: [id], onDelete: Cascade)

  @@unique([sourceProductId, targetProductId, relationType])
  @@index([targetProductId, relationType])
  @@index([sourceProductId, source])
}

model ProductBarcode {
  id        String         @id @default(cuid())
  variantId String
  code      String         @unique
  isPrimary Boolean        @default(false)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
}

model CatalogImportBatch {
  id                     String                  @id @default(cuid())
  provider               CatalogImportProvider
  sourceFileName         String
  fileSha256             String
  analysisVersion        String                  @default("legacy")
  status                 CatalogImportStatus     @default(STAGED)
  report                 Json?
  applyReport            Json?
  approvedBy             String?
  approvedAt             DateTime?
  appliedBy              String?
  appliedAt              DateTime?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  rows                   CatalogImportRow[]
  brandResolutionReviews BrandResolutionReview[]

  @@unique([provider, fileSha256, analysisVersion])
  @@index([provider, createdAt])
  @@index([fileSha256])
}

model CatalogImportRow {
  id                    String                  @id @default(cuid())
  batchId               String
  entityType            CatalogImportEntityType
  sourceRowNumber       Int
  externalId            String?
  sku                   String?
  rawPayload            Json
  parsedPayload         Json
  issues                Json
  status                CatalogImportRowStatus
  createdAt             DateTime                @default(now())
  batch                 CatalogImportBatch      @relation(fields: [batchId], references: [id], onDelete: Cascade)
  brandResolutionReview BrandResolutionReview?

  @@unique([batchId, entityType, sourceRowNumber])
  @@index([batchId, status])
  @@index([entityType, externalId])
  @@index([entityType, sku])
}

model BrandResolutionReview {
  id               String                      @id @default(cuid())
  batchId          String
  importRowId      String                      @unique
  sourceRowNumber  Int
  sku              String
  productName      String
  status           BrandResolutionReviewStatus @default(PENDING)
  proposedBrandKey String?
  resolvedBrandKey String?
  reviewedBy       String?
  reviewedAt       DateTime?
  confidence       Int
  reviewReasons    Json
  resolution       Json
  resolverVersion  String
  configVersion    String
  schemaVersion    String
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  batch            CatalogImportBatch          @relation(fields: [batchId], references: [id], onDelete: Cascade)
  importRow        CatalogImportRow            @relation(fields: [importRowId], references: [id], onDelete: Cascade)

  @@unique([batchId, sourceRowNumber])
  @@index([batchId, status])
  @@index([proposedBrandKey, status])
}

model Supplier {
  id         String   @id @default(cuid())
  code       String   @unique
  name       String
  /// EU-s beszállítónál a közösségi adószám (pl. "DE123456789"), belföldinél a magyar adószám; opcionális.
  taxNumber  String?
  /// ISO 3166-1 alpha-2 országkód; a "HU"-tól eltérő érték jelöli az EU-n belüli beszerzést.
  country    String   @default("HU") @db.VarChar(2)
  email      String?
  phone      String?
  /// EU-s (nem "HU") beszállítónál a nemzetközi bankszámlaszám.
  iban              String?
  /// EU-s (nem "HU") beszállítónál a bank SWIFT/BIC kódja.
  swiftCode         String?
  /// Belföldi ("HU") beszállítónál a hazai formátumú bankszámlaszám.
  bankAccountNumber String?
  /// Kapcsolattartó neve, mindkét beszállítói körnél.
  contactPersonName  String?
  contactPersonPhone String?
  contactPersonEmail String?
  /// Cím adatok; a "country" mező (fent) az irányadó országkód, itt nincs külön tárolva.
  postalCode   String?
  city         String?
  addressLine1 String?
  addressLine2 String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  products              SupplierProduct[]
  purchaseOrders        PurchaseOrder[]
  purchaseInvoices      PurchaseInvoice[]
  preferredByExtensions ProductExtension[]
  invoices              Invoice[]

  @@index([country, isActive])
}

model SupplierProduct {
  id                   String         @id @default(cuid())
  supplierId           String
  variantId            String
  supplierSku          String
  supplierName         String?
  lastPurchaseNet      Decimal?       @db.Decimal(19, 4)
  currency             String         @default("HUF") @db.VarChar(3)
  minimumOrderQuantity Decimal?       @db.Decimal(19, 6)
  packageSize          Decimal?       @db.Decimal(19, 6)
  leadTimeDays         Int?
  supplier             Supplier       @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  variant              ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([supplierId, supplierSku])
  @@unique([supplierId, variantId])
}

model Warehouse {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locations            WarehouseLocation[]
  stockItems           StockItem[]
  sourceMovements      StockMovement[]     @relation("MovementSourceWarehouse")
  targetMovements      StockMovement[]     @relation("MovementTargetWarehouse")
  purchaseOrders       PurchaseOrder[]
  goodsReceipts        GoodsReceipt[]
  purchaseInvoices     PurchaseInvoice[]
  defaultForExtensions ProductExtension[]
  inventoryCounts      InventoryCount[]
  salesOrders          SalesOrder[]
}

model WarehouseLocation {
  id          String   @id @default(cuid())
  warehouseId String
  code        String
  name        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse            Warehouse           @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  stockItems           StockItem[]
  sourceMovementLines  StockMovementLine[] @relation("MovementSourceLocation")
  targetMovementLines  StockMovementLine[] @relation("MovementTargetLocation")
  defaultForExtensions ProductExtension[]

  @@unique([warehouseId, code])
}

/// UNAS-owned product fields mirrored for read-only operational use.
/// Reported stock is a comparison snapshot and never the local stock ledger.
model UnasProductSnapshot {
  id                             String    @id @default(cuid())
  productId                      String    @unique
  currency                       String?   @db.VarChar(3)
  netPrice                       Decimal?  @db.Decimal(19, 4)
  grossPrice                     Decimal?  @db.Decimal(19, 4)
  saleNetPrice                   Decimal?  @db.Decimal(19, 4)
  saleGrossPrice                 Decimal?  @db.Decimal(19, 4)
  saleStartsAt                   DateTime?
  saleEndsAt                     DateTime?
  priceDisplay                   String?
  descriptionShort               String?
  descriptionLong                String?
  descriptionShortIsHtml         Boolean?
  descriptionLongIsHtml          Boolean?
  productUrl                     String?
  sefUrl                         String?
  manufacturerUrl                String?
  vatRate                        Decimal?  @db.Decimal(5, 2)
  propertiesHtml                 String?
  minimumOrderQuantity           Decimal?  @db.Decimal(19, 6)
  initialOrderQuantity           Decimal?  @db.Decimal(19, 6)
  maximumOrderQuantity           Decimal?  @db.Decimal(19, 6)
  orderQuantityStep              Decimal?  @db.Decimal(19, 6)
  backorderAllowed               Boolean?
  variantStockEnabled            Boolean?
  lowStockThreshold              Decimal?  @db.Decimal(19, 6)
  reportedStock                  Decimal?  @db.Decimal(19, 6)
  reportedStockSyncedAt          DateTime?
  primaryCategoryExternalId      String?
  alternativeCategoryExternalIds Json?
  images                         Json?
  parameters                     Json?
  seo                            Json?
  rawPayload                     Json
  createdAt                      DateTime  @default(now())
  updatedAt                      DateTime  @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

/// Acropora-owned static operational settings for a sellable/stockable variant.
/// Purchase cost history belongs to GoodsReceiptLine, not this model.
model ProductExtension {
  id                      String   @id @default(cuid())
  variantId               String   @unique
  preferredSupplierId     String?
  defaultPurchaseCurrency String?  @db.VarChar(3)
  defaultWarehouseId      String?
  defaultLocationId       String?
  minimumStock            Decimal? @db.Decimal(19, 6)
  optimalStock            Decimal? @db.Decimal(19, 6)
  reorderPoint            Decimal? @db.Decimal(19, 6)
  safetyStock             Decimal? @db.Decimal(19, 6)
  lastPurchaseNetPrice    Decimal? @db.Decimal(19, 6)
  lastPurchaseVatRate     Decimal? @db.Decimal(5, 2)
  stockTrackingEnabled    Boolean  @default(true)
  purchasingDisabled      Boolean  @default(false)
  phaseOut                Boolean  @default(false)
  autoReorderEnabled      Boolean  @default(false)
  internalNote            String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  variant           ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  preferredSupplier Supplier?          @relation(fields: [preferredSupplierId], references: [id], onDelete: SetNull)
  defaultWarehouse  Warehouse?         @relation(fields: [defaultWarehouseId], references: [id], onDelete: SetNull)
  defaultLocation   WarehouseLocation? @relation(fields: [defaultLocationId], references: [id], onDelete: SetNull)

  @@index([preferredSupplierId])
  @@index([defaultWarehouseId])
  @@index([defaultLocationId])
}

/// Read-optimized projection rebuilt from posted stock movement lines; never the stock source of truth.
model StockItem {
  id          String   @id @default(cuid())
  variantId   String
  warehouseId String
  locationId  String?
  lotId       String?
  onHand      Decimal  @default(0) @db.Decimal(19, 6)
  reserved    Decimal  @default(0) @db.Decimal(19, 6)
  updatedAt   DateTime @updatedAt

  variant   ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouse Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  location  WarehouseLocation? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  @@unique([variantId, warehouseId, locationId, lotId])
  @@index([warehouseId, variantId])
}

model StockMovement {
  id                String              @id @default(cuid())
  movementNumber    String              @unique
  type              StockMovementType
  status            StockMovementStatus @default(DRAFT)
  sourceWarehouseId String?
  targetWarehouseId String?
  referenceType     String?
  referenceId       String?
  note              String?
  occurredAt        DateTime
  postedAt          DateTime?
  performedById     String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  sourceWarehouse Warehouse?          @relation("MovementSourceWarehouse", fields: [sourceWarehouseId], references: [id])
  targetWarehouse Warehouse?          @relation("MovementTargetWarehouse", fields: [targetWarehouseId], references: [id])
  performedBy     User?               @relation(fields: [performedById], references: [id], onDelete: SetNull)
  lines           StockMovementLine[]

  @@index([status, occurredAt])
  @@index([referenceType, referenceId])
}

model StockMovementLine {
  id               String  @id @default(cuid())
  movementId       String
  variantId        String
  sourceLocationId String?
  targetLocationId String?
  quantity         Decimal @db.Decimal(19, 6)
  unit             String
  lotId            String?
  serialNumberId   String?

  movement       StockMovement      @relation(fields: [movementId], references: [id], onDelete: Cascade)
  variant        ProductVariant     @relation(fields: [variantId], references: [id])
  sourceLocation WarehouseLocation? @relation("MovementSourceLocation", fields: [sourceLocationId], references: [id])
  targetLocation WarehouseLocation? @relation("MovementTargetLocation", fields: [targetLocationId], references: [id])

  @@index([variantId])
  @@index([movementId])
}

/// Egy leltározási folyamat: Excel-exporttal induló, felhasználó által
/// kitöltött, majd visszatöltött darabszám-számlálás, amiből egy StockMovement
/// (ADJUSTMENT) korrekció és UNAS setStock push készül.
model InventoryCount {
  id          String               @id @default(cuid())
  countNumber String               @unique
  warehouseId String
  status      InventoryCountStatus @default(DRAFT)
  startedById String?
  uploadedAt  DateTime?
  correctedAt DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  warehouse Warehouse            @relation(fields: [warehouseId], references: [id])
  startedBy User?                @relation(fields: [startedById], references: [id], onDelete: SetNull)
  lines     InventoryCountLine[]

  @@index([status, createdAt])
}

model InventoryCountLine {
  id               String                        @id @default(cuid())
  inventoryCountId String
  variantId        String
  expectedQty      Decimal                        @db.Decimal(19, 6)
  countedQty       Decimal?                       @db.Decimal(19, 6)
  syncStatus       InventoryCountLineSyncStatus   @default(PENDING)
  syncError        String?

  inventoryCount InventoryCount @relation(fields: [inventoryCountId], references: [id], onDelete: Cascade)
  variant        ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([inventoryCountId, variantId])
  @@index([inventoryCountId])
}

model Customer {
  id                    String       @id @default(cuid())
  customerNumber        String       @unique
  type                  CustomerType
  displayName           String
  companyName           String?
  taxNumber             String?
  email                 String?
  phone                 String?
  marketingEmailConsent Boolean      @default(false)
  marketingSmsConsent   Boolean      @default(false)
  isActive              Boolean      @default(true)
  archivedAt            DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  addresses   CustomerAddress[]
  salesOrders SalesOrder[]
  aquariums   Aquarium[]
  serviceJobs ServiceJob[]
  invoices    Invoice[]

  @@index([displayName])
  @@index([email])
}

model CustomerAddress {
  id         String      @id @default(cuid())
  customerId String
  type       AddressType
  name       String?
  country    String      @default("HU") @db.VarChar(2)
  postalCode String
  city       String
  line1      String
  line2      String?
  isDefault  Boolean     @default(false)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId, type])
}

model SalesOrder {
  id               String            @id @default(cuid())
  orderNumber      String            @unique
  customerId       String?
  channel          SalesChannel
  status           SalesOrderStatus  @default(DRAFT)
  currency         String            @default("HUF") @db.VarChar(3)
  totalNet         Decimal           @default(0) @db.Decimal(19, 4)
  totalTax         Decimal           @default(0) @db.Decimal(19, 4)
  totalGross       Decimal           @default(0) @db.Decimal(19, 4)
  /// Melyik raktárból ment/megy ki az áru (POS és UNAS webshop rendeléseknél is kitöltött).
  warehouseId      String?
  /// A pénztárt kezelő felhasználó (POS eladásoknál).
  soldById         String?
  /// A kiegyenlítés módja (jelenleg csak POS eladásoknál kötelező).
  paymentMethod    PosPaymentMethod?
  /// Előkészítve a jövőbeli számlázz.hu integrációhoz; ma még nem használt.
  invoiceRequested Boolean           @default(false)
  /// Webshop (UNAS) rendeléseknél a vásárló neve; nincs még Customer modul,
  /// ezért csak megjelenítésre tárolt sima szöveg, nem kapcsolt entitás.
  buyerName        String?
  buyerEmail       String?
  orderedAt        DateTime?
  confirmedAt      DateTime?
  completedAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  customer  Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  warehouse Warehouse?       @relation(fields: [warehouseId], references: [id], onDelete: SetNull)
  soldBy    User?            @relation(fields: [soldById], references: [id], onDelete: SetNull)
  lines     SalesOrderLine[]

  @@index([status, createdAt])
  @@index([customerId, createdAt])
  @@index([channel, createdAt])
}

model SalesOrderLine {
  id          String                   @id @default(cuid())
  orderId     String
  variantId   String?
  sku         String
  description String
  quantity    Decimal                  @db.Decimal(19, 6)
  unit        String
  unitNet     Decimal                  @db.Decimal(19, 4)
  taxRate     Decimal                  @db.Decimal(5, 2)
  lineGross   Decimal                  @db.Decimal(19, 4)
  /// UNAS setStock push kimenetele erre a tételre (POS eladásoknál).
  syncStatus  SalesOrderLineSyncStatus @default(PENDING)
  syncError   String?

  order   SalesOrder      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([variantId])
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  orderNumber String              @unique
  supplierId  String
  warehouseId String
  status      PurchaseOrderStatus @default(DRAFT)
  currency    String              @default("HUF") @db.VarChar(3)
  expectedAt  DateTime?
  approvedAt  DateTime?
  sentAt      DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  supplier  Supplier            @relation(fields: [supplierId], references: [id])
  warehouse Warehouse           @relation(fields: [warehouseId], references: [id])
  lines     PurchaseOrderLine[]
  receipts  GoodsReceipt[]

  @@index([supplierId, status])
  @@index([warehouseId, expectedAt])
}

model PurchaseOrderLine {
  id               String    @id @default(cuid())
  purchaseOrderId  String
  variantId        String
  supplierSku      String?
  description      String
  orderedQuantity  Decimal   @db.Decimal(19, 6)
  receivedQuantity Decimal   @default(0) @db.Decimal(19, 6)
  unit             String
  unitNet          Decimal   @db.Decimal(19, 4)
  taxRate          Decimal?  @db.Decimal(5, 2)
  expectedAt       DateTime?

  purchaseOrder PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  variant       ProductVariant     @relation(fields: [variantId], references: [id])
  receiptLines  GoodsReceiptLine[]

  @@index([purchaseOrderId])
  @@index([variantId])
}

model GoodsReceipt {
  id              String             @id @default(cuid())
  receiptNumber   String             @unique
  purchaseOrderId String
  warehouseId     String
  status          GoodsReceiptStatus @default(DRAFT)
  receivedAt      DateTime
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  purchaseOrder PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])
  warehouse     Warehouse          @relation(fields: [warehouseId], references: [id])
  lines         GoodsReceiptLine[]

  @@index([purchaseOrderId, receivedAt])
}

model GoodsReceiptLine {
  id                  String   @id @default(cuid())
  goodsReceiptId      String
  purchaseOrderLineId String
  variantId           String
  receivedQuantity    Decimal  @db.Decimal(19, 6)
  acceptedQuantity    Decimal  @db.Decimal(19, 6)
  rejectedQuantity    Decimal  @default(0) @db.Decimal(19, 6)
  unitNet             Decimal? @db.Decimal(19, 4)

  goodsReceipt      GoodsReceipt      @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  purchaseOrderLine PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id])
  variant           ProductVariant    @relation(fields: [variantId], references: [id])

  @@unique([goodsReceiptId, purchaseOrderLineId])
}

/// Beérkezett beszállítói számla rögzítése: nálunk ez maga a beszerzés
/// bevételezési eseménye, nincs külön előzetes rendelés-jóváhagyási lépés
/// (lásd docs/DOMAIN-MODEL.md-től eltérő, tényleges üzleti folyamat). A
/// PurchaseOrder/GoodsReceipt pár változatlanul megmarad, de ez a modell nem
/// épül rájuk.
model PurchaseInvoice {
  id                    String                @id @default(cuid())
  /// Belső, generált bizonylatszám (pl. "BESZ-...").
  documentNumber        String                @unique
  /// A beszállítói számlán szereplő tényleges számlaszám.
  supplierInvoiceNumber String
  source                PurchaseInvoiceSource
  status                PurchaseInvoiceStatus @default(POSTED)
  supplierId            String
  warehouseId           String
  /// ISO 4217 pénznemkód; belföldi/HUF esetén nincs átváltás.
  currency              String                @default("HUF") @db.VarChar(3)
  /// MNB hivatalos árfolyam a számla keltének napján, HUF/deviza egységre; HUF számlánál null.
  exchangeRate          Decimal?              @db.Decimal(19, 6)
  invoiceDate           DateTime
  dueDate               DateTime?
  isPaid                Boolean               @default(false)
  paidAt                DateTime?
  /// Belföldi kézi rögzítésnél használt ÁFA-kulcs (alapértelmezetten 27); EU-s számlánál jellemzően null.
  vatRate               Decimal?              @db.Decimal(5, 2)
  note                  String?
  createdById           String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  supplier  Supplier              @relation(fields: [supplierId], references: [id])
  warehouse Warehouse             @relation(fields: [warehouseId], references: [id])
  createdBy User?                 @relation(fields: [createdById], references: [id], onDelete: SetNull)
  lines     PurchaseInvoiceLine[]
  /// Ha a számla egy NAV-ból lekérdezett belföldi bejövő számla
  /// bevételezéseként jött létre - a fordított irányú, opcionális kapcsolat
  /// a NavIncomingInvoice oldalán él (purchaseInvoiceId).
  navIncomingInvoice NavIncomingInvoice?

  @@unique([supplierId, supplierInvoiceNumber])
  @@index([status, invoiceDate])
  @@index([warehouseId])
}

model PurchaseInvoiceLine {
  id                String   @id @default(cuid())
  purchaseInvoiceId String
  /// Opcionális: ha a számla tétele nincs a terméktörzsben (pl. egyszeri
  /// tétel, vagy a termék felvétele még nem történt meg), a sor variant
  /// nélkül is rögzíthető - ilyenkor nincs helyi készlethatás és UNAS
  /// szinkron sem (lásd syncStatus "NOT_LINKED").
  variantId         String?
  /// A számlán szereplő eredeti (nem a saját) megnevezés; variant nélküli
  /// sornál ez az egyetlen megnevezés, ezért ilyenkor kötelező.
  sourceDescription String?
  orderedQuantity   Decimal  @db.Decimal(19, 6)
  actualQuantity    Decimal  @db.Decimal(19, 6)
  unit              String
  /// Egységár a számla pénznemében, kedvezmény levonása előtt.
  unitNet           Decimal  @db.Decimal(19, 4)
  discountPercent   Decimal? @db.Decimal(5, 2)
  /// A tétel UNAS készlet-push eredménye (OK / FAILED / PENDING / NOT_LINKED
  /// - utóbbi: nincs terméktörzsbeli variant, nincs mit szinkronizálni).
  syncStatus        String   @default("PENDING")
  syncError         String?

  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  variant         ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([purchaseInvoiceId])
  @@index([variantId])
}

/// A NAV Online Számla queryInvoiceDigest szinkronból lekerülő belföldi
/// bejövő (INBOUND irányú) számla lokális tükre. A digest-lekérdezés csak
/// egy kivonatot ad (lásd NEW állapot); a teljes tétellista csak a
/// queryInvoiceData lusta (részletnézetkori) hívásakor kerül le és
/// parszolódik a parsedData mezőbe (lásd nav-invoice-data.parser.ts) -
/// nincs értelme minden digest-sorhoz azonnal lekérni a teljes adatot,
/// hiszen a legtöbb sosem kerül ténylegesen bevételezésre.
model NavIncomingInvoice {
  id                  String                   @id @default(cuid())
  navInvoiceNumber    String
  supplierTaxNumber   String
  supplierName        String
  invoiceIssueDate    DateTime
  invoiceDeliveryDate DateTime?
  paymentDate         DateTime?
  currency            String                   @default("HUF") @db.VarChar(3)
  invoiceNetAmount    Decimal?                 @db.Decimal(19, 2)
  invoiceVatAmount    Decimal?                 @db.Decimal(19, 2)
  /// A NAV-oldali regisztrálás időpontja - ez a szinkron kurzor alapja
  /// (lásd IntegrationCursor provider="NAV" stream="INBOUND_INVOICES"),
  /// nem az invoiceIssueDate (ami a kiállító által megadott, nem a NAV
  /// szerver órája szerinti időpont).
  insDate             DateTime
  status              NavIncomingInvoiceStatus @default(NEW)
  /// A queryInvoiceData válaszból felparszolt, bevételezéshez szükséges
  /// pillanatkép (beszállító adatok, cím, tételek) - lásd
  /// ParsedNavInvoiceData (nav-invoice-data.parser.ts). Csak DATA_FETCHED
  /// vagy RECEIVED állapotban nem null.
  parsedData          Json?
  errorCode           String?
  purchaseInvoiceId   String?                  @unique
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  purchaseInvoice PurchaseInvoice? @relation(fields: [purchaseInvoiceId], references: [id], onDelete: SetNull)

  @@unique([navInvoiceNumber, supplierTaxNumber])
  @@index([status, insDate])
}

/// Egy NAV bejövő-számla digest-szinkron futás: az insDate kurzoron alapuló,
/// a UnasCustomerSyncRun mintáját követő ablakos lekérdezés (nincs
/// FULL/INCREMENTAL megkülönböztetés, minden futás a kurzor óta regisztrált
/// ablakot dolgozza fel).
model NavInvoiceSyncRun {
  id           String                  @id @default(cuid())
  activeKey    String?                 @unique
  status       NavInvoiceSyncRunStatus @default(PENDING)
  windowStart  DateTime?
  windowEnd    DateTime
  startedAt    DateTime?
  completedAt  DateTime?
  invoicesSeen Int                     @default(0)
  createdCount Int                     @default(0)
  /// A digest-ben szereplő, de v1-ben szándékosan figyelmen kívül hagyott
  /// MODIFY/STORNO műveletű tételek száma (lásd docs/CURRENT_STATUS.md).
  skippedCount Int                     @default(0)
  errorCode    String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  @@index([status, createdAt])
}

/// A teljes bejövő+kimenő számlanyilvántartás (M8.4, ADR-005). Ez a
/// Számlázz.hu push-fogadásból (elsődleges forrás) és a NAV napi
/// egyeztetésből (másodlagos, ellenőrző forrás) táplálkozó, cégszintű
/// számlaregiszter - NEM azonos a PurchaseInvoice-zal, ami a fizikai
/// bevételezési/készlet-workflow bizonylata. Egy adott üzleti eseménynek
/// (pl. egy beszállítói számla beérkezése) elvben mindkét oldalon lehet
/// nyoma: a PurchaseInvoice a raktári bevételezést, az Invoice a pénzügyi
/// nyilvántartást rögzíti. Az összekapcsolásuk (pl. közös
/// supplierInvoiceNumber alapján) még nem implementált - lásd a
/// docs/DECISIONS.md ADR-005 nyitott kérdését erről.
model Invoice {
  id           String              @id @default(cuid())
  direction    InvoiceDirection
  documentType InvoiceDocumentType @default(INVOICE)
  source       InvoiceSource
  /// A Számlázz.hu belső <alap><id> azonosítója - ez az idempotens upsert
  /// kulcsa a bejövő/kimenő push fogadásakor (M8.3). NAV/MANUAL/IMPORT
  /// forrásnál jellemzően null.
  szamlazzInvoiceId String?
  /// A ténylegesen kiállított/kapott számla saját, emberi olvasható száma.
  invoiceNumber     String
  partnerName       String
  partnerTaxNumber  String?
  customerId        String?
  supplierId        String?
  issueDate         DateTime
  fulfillmentDate   DateTime?
  dueDate           DateTime?
  /// ISO 4217 pénznemkód.
  currency          String              @default("HUF") @db.VarChar(3)
  exchangeRate      Decimal?            @db.Decimal(19, 6)
  netAmount         Decimal             @db.Decimal(19, 4)
  vatAmount         Decimal             @db.Decimal(19, 4)
  grossAmount       Decimal             @db.Decimal(19, 4)
  isPaid            Boolean             @default(false)
  paidAt            DateTime?
  /// Sztornó/helyesbítő bizonylatnál az eredeti számlára mutat.
  referencedInvoiceId String?
  syncStatus        InvoiceSyncStatus   @default(PENDING)
  syncError         String?
  /// Nyers XML megőrzése objektumtár-kulcsként, nem DB-blobként (7.5).
  rawPayloadStorageKey String?
  pdfStorageKey     String?
  bookkeepingStatus String?
  tags              String[]
  note              String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  customer           Customer?     @relation(fields: [customerId], references: [id])
  supplier            Supplier?     @relation(fields: [supplierId], references: [id])
  referencedInvoice   Invoice?      @relation("InvoiceCorrectionChain", fields: [referencedInvoiceId], references: [id])
  correctionInvoices  Invoice[]     @relation("InvoiceCorrectionChain")
  lines               InvoiceLine[]

  @@unique([source, szamlazzInvoiceId])
  @@index([direction, issueDate])
  @@index([partnerTaxNumber])
  @@index([syncStatus])
}

model InvoiceLine {
  id             String  @id @default(cuid())
  invoiceId      String
  description    String
  quantity       Decimal @db.Decimal(19, 6)
  unit           String?
  unitNet        Decimal @db.Decimal(19, 4)
  vatRatePercent Decimal @db.Decimal(5, 2)
  netAmount      Decimal @db.Decimal(19, 4)
  vatAmount      Decimal @db.Decimal(19, 4)
  grossAmount    Decimal @db.Decimal(19, 4)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model ServiceJob {
  id             String           @id @default(cuid())
  jobNumber      String           @unique
  customerId     String?
  aquariumId     String?
  status         ServiceJobStatus @default(NEW)
  title          String
  description    String?
  assignedUserId String?
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  aquarium Aquarium? @relation(fields: [aquariumId], references: [id], onDelete: SetNull)

  @@index([status, scheduledAt])
  @@index([customerId])
}

model Aquarium {
  id                 String                @id @default(cuid())
  aquariumNumber     String                @unique
  customerId         String?
  name               String
  ownershipType      AquariumOwnershipType
  lengthCm           Decimal?              @db.Decimal(10, 2)
  widthCm            Decimal?              @db.Decimal(10, 2)
  heightCm           Decimal?              @db.Decimal(10, 2)
  systemVolumeLiters Decimal?              @db.Decimal(12, 3)
  maintainedByUs     Boolean               @default(false)
  responsibleUserId  String?
  isActive           Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  customer     Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  measurements AquariumMeasurement[]
  serviceJobs  ServiceJob[]

  @@index([customerId, isActive])
}

model AquariumMeasurement {
  id            String   @id @default(cuid())
  aquariumId    String
  parameterCode String
  value         Decimal  @db.Decimal(19, 6)
  unit          String
  measuredAt    DateTime
  measuredById  String?
  source        String?
  notes         String?
  createdAt     DateTime @default(now())
  aquarium      Aquarium @relation(fields: [aquariumId], references: [id], onDelete: Cascade)

  @@index([aquariumId, parameterCode, measuredAt])
}

model IcpReport {
  id             String      @id @default(cuid())
  reportNumber   String      @unique
  aquariumId     String?
  laboratoryCode String
  sampledAt      DateTime?
  reportedAt     DateTime?
  sourceFileUrl  String?
  sourceFileHash String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  results        IcpResult[]

  @@index([aquariumId, reportedAt])
  @@index([laboratoryCode, reportedAt])
}

model IcpResult {
  id          String    @id @default(cuid())
  reportId    String
  elementCode String
  value       Decimal   @db.Decimal(19, 8)
  unit        String
  minimum     Decimal?  @db.Decimal(19, 8)
  maximum     Decimal?  @db.Decimal(19, 8)
  target      Decimal?  @db.Decimal(19, 8)
  trend       String?
  report      IcpReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, elementCode])
}

model ExternalReference {
  id           String         @id @default(cuid())
  system       ExternalSystem
  entityType   String
  entityId     String
  externalId   String
  externalKey  String?
  metadata     Json?
  lastSyncedAt DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([system, entityType, externalId])
  @@unique([system, entityType, entityId])
  @@index([entityType, entityId])
}

model IntegrationSyncState {
  id             String     @id @default(cuid())
  provider       String
  operation      String
  aggregateType  String
  aggregateId    String
  idempotencyKey String     @unique
  status         SyncStatus @default(PENDING)
  attempts       Int        @default(0)
  nextAttemptAt  DateTime?
  lastError      String?
  payload        Json
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([status, nextAttemptAt])
}

model IntegrationCursor {
  id                      String    @id @default(cuid())
  provider                String
  stream                  String
  lastSuccessfulWindowEnd DateTime?
  updatedAt               DateTime  @updatedAt

  @@unique([provider, stream])
}

model UnasConnectionSetting {
  id                        String                 @id
  credentialMode            UnasCredentialMode     @default(ENV_FALLBACK)
  encryptedApiKey           Bytes?
  encryptionIv              Bytes?
  authenticationTag         Bytes?
  keyVersion                String?
  credentialRevision        Int                    @default(0)
  credentialUpdatedAt       DateTime?
  credentialUpdatedByUserId String?
  verificationStatus        UnasVerificationStatus @default(NEVER)
  lastVerifiedAt            DateTime?
  lastVerificationCode      String?
  credentialAttemptedAt     DateTime?
  testAttemptedAt           DateTime?
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt

  credentialUpdatedBy User? @relation("UnasCredentialUpdatedBy", fields: [credentialUpdatedByUserId], references: [id], onDelete: SetNull)

  @@index([credentialUpdatedByUserId])
}

/// Számlázz.hu kapcsolatbeállítás (M8.1, ADR-005) - az UnasConnectionSetting
/// mintáját követi, de két, egymástól független titkosított credentiallel:
/// az Agent kulcs (kimenő automatikus számlázáshoz, M8.2) és a pénzügyi
/// adatkapcsolati kulcs (bejövő/kimenő push fogadás hitelesítéséhez, M8.3)
/// külön kezelendő, mert eltérő Számlázz.hu-oldali jogosultsághoz
/// tartoznak, és külön is rotálhatók/tilthatók.
model SzamlazzConnectionSetting {
  id                  String                     @id
  credentialMode      SzamlazzCredentialMode     @default(ENV_FALLBACK)

  encryptedAgentKey         Bytes?
  agentKeyEncryptionIv      Bytes?
  agentKeyAuthenticationTag Bytes?
  agentKeyVersion           String?

  encryptedFinancialApiKey         Bytes?
  financialApiKeyEncryptionIv      Bytes?
  financialApiKeyAuthenticationTag Bytes?
  financialApiKeyVersion           String?

  credentialRevision        Int                        @default(0)
  credentialUpdatedAt        DateTime?
  credentialUpdatedByUserId String?
  verificationStatus        SzamlazzVerificationStatus @default(NEVER)
  lastVerifiedAt             DateTime?
  lastVerificationCode      String?
  credentialAttemptedAt      DateTime?
  testAttemptedAt            DateTime?
  /// M8.5: a visszamenőleges backfill kezdődátuma, a kapcsolat
  /// aktiválásakor rögzítve - a bulk betöltés ehhez képest dolgozik.
  backfillStartDate         DateTime?
  createdAt                  DateTime                   @default(now())
  updatedAt                  DateTime                   @updatedAt

  credentialUpdatedBy User? @relation("SzamlazzCredentialUpdatedBy", fields: [credentialUpdatedByUserId], references: [id], onDelete: SetNull)

  @@index([credentialUpdatedByUserId])
}

model UnasProductSyncRun {
  id             String                   @id @default(cuid())
  activeKey      String?                  @unique
  kind           UnasProductSyncKind
  status         UnasProductSyncRunStatus @default(PENDING)
  windowStart    DateTime?
  windowEnd      DateTime
  startedAt      DateTime?
  completedAt    DateTime?
  productsSeen   Int                      @default(0)
  createdCount   Int                      @default(0)
  updatedCount   Int                      @default(0)
  unchangedCount Int                      @default(0)
  conflictCount  Int                      @default(0)
  missingCount   Int                      @default(0)
  errorCode      String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@index([status, createdAt])
  @@index([kind, completedAt])
}

/// Egy webshop (UNAS) rendelés-szinkron futás: a getOrder TimeModStart
/// kurzor alapján lekért, új vagy módosult rendelések feldolgozása.
/// Nincs FULL/INCREMENTAL megkülönböztetés (a UnasProductSyncRun-nal
/// ellentétben) - alacsony rendelésszám mellett minden futás ugyanazt az
/// egy "ami a kurzor óta módosult" ablakot dolgozza fel.
model UnasOrderSyncRun {
  id                 String                 @id @default(cuid())
  activeKey          String?                @unique
  status             UnasOrderSyncRunStatus @default(PENDING)
  windowStart        DateTime?
  windowEnd          DateTime
  startedAt          DateTime?
  completedAt        DateTime?
  ordersSeen         Int                    @default(0)
  createdCount       Int                    @default(0)
  updatedCount       Int                    @default(0)
  reversedCount      Int                    @default(0)
  stockMismatchCount Int                    @default(0)
  errorCode          String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  @@index([status, createdAt])
}

/// Egy webshop (UNAS) vásárló-szinkron futás: a getCustomer ModTimeStart
/// kurzoron alapuló, új vagy módosult vásárlók feldolgozása. Az
/// UnasOrderSyncRun mintáját követi: nincs FULL/INCREMENTAL megkülönböztetés,
/// minden futás a kurzor óta módosult ablakot dolgozza fel. A UNAS oldali
/// azonosítót (Customer.Id) kizárólag ExternalReference tárolja, a Customer
/// modellen nincs UNAS-specifikus mező (ld. ADR-0009).
model UnasCustomerSyncRun {
  id             String                     @id @default(cuid())
  activeKey      String?                    @unique
  status         UnasCustomerSyncRunStatus  @default(PENDING)
  windowStart    DateTime?
  windowEnd      DateTime
  startedAt      DateTime?
  completedAt    DateTime?
  customersSeen  Int                        @default(0)
  createdCount   Int                        @default(0)
  updatedCount   Int                        @default(0)
  unchangedCount Int                        @default(0)
  errorCode      String?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  @@index([status, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([entityType, entityId, createdAt])
}

model DomainEvent {
  id            String    @id
  eventType     String
  aggregateType String
  aggregateId   String
  actorUserId   String?
  correlationId String?
  payload       Json
  schemaVersion Int       @default(1)
  occurredAt    DateTime
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([aggregateType, aggregateId, occurredAt])
  @@index([publishedAt, occurredAt])
  @@index([correlationId])
}
