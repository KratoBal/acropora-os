{
  "name": "acropora-erp",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10",
  "scripts": {
    "infra:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker/docker-compose.yml down",
    "db:validate": "prisma validate --schema packages/database/prisma/schema.prisma",
    "db:format": "prisma format --schema packages/database/prisma/schema.prisma"
  },
  "devDependencies": {
    "prisma": "^6.0.0"
  }
}
