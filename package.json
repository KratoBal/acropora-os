{
  "name": "acropora-os",
  "version": "0.1.0",
  "private": true,
  "description": "Magyar nyelvű, moduláris vállalatirányítási rendszer.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.34.5",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --filter=@acropora/web --filter=@acropora/api",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "db:validate": "pnpm --filter @acropora/database db:validate",
    "db:format": "pnpm --filter @acropora/database db:format",
    "prisma:generate": "pnpm --filter @acropora/database prisma:generate",
    "prisma:migrate": "pnpm --filter @acropora/database prisma:migrate",
    "prisma:push": "pnpm --filter @acropora/database prisma:push",
    "prisma:studio": "pnpm --filter @acropora/database prisma:studio",
    "prisma:seed": "pnpm --filter @acropora/database prisma:seed"
  },
  "devDependencies": {
    "prettier": "^3.9.5",
    "turbo": "^2.10.5",
    "typescript": "^6.0.3"
  }
}
