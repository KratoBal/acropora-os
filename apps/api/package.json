{
  "name": "@acropora/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "tsc --noEmit",
    "test": "tsc -p tsconfig.test.json && node --test test-dist/auth/guards/permission.guard.spec.js test-dist/brands/brands.service.spec.js test-dist/products/product.repository.spec.js test-dist/products/product.service.spec.js test-dist/products/product.controller.spec.js test-dist/imports/unas/unas-import.spec.js test-dist/imports/unas/unas-apply.service.spec.js test-dist/imports/unas/unas-brand-review.service.spec.js test-dist/imports/unas/brand-resolution/brand-resolution.spec.js test-dist/imports/unas/unas-import.integration.spec.js test-dist/imports/unas/unas-apply.integration.spec.js",
    "test:integration": "tsc -p tsconfig.test.json && RUN_DB_INTEGRATION=1 node --test --test-concurrency=1 test-dist/imports/unas/unas-import.integration.spec.js test-dist/imports/unas/unas-apply.integration.spec.js",
    "test:brands:integration": "tsc -p tsconfig.test.json && RUN_BRAND_INTEGRATION=1 node --test --test-concurrency=1 test-dist/brands/brands.integration.spec.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@acropora/database": "workspace:*",
    "@acropora/types": "workspace:*",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-express": "^11.1.28",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "exceljs": "4.4.0",
    "multer": "2.2.0",
    "redis": "^6.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@acropora/config": "workspace:*",
    "@nestjs/cli": "^11.0.24",
    "@types/multer": "2.2.0",
    "@types/node": "^26.1.1",
    "typescript": "^6.0.3"
  }
}
