# Futási környezet. Helyi fejlesztéshez maradjon development.
NODE_ENV=development

# PostgreSQL kapcsolat a gyökér docker-compose.yml szolgáltatásához.
DATABASE_URL=postgresql://acropora:acropora@localhost:5432/acropora?schema=public&connect_timeout=2

# Redis kapcsolat queue-khoz, cache-hez és health ellenőrzéshez.
REDIS_URL=redis://localhost:6379

# A felhasználók által elért webalkalmazás publikus címe.
APP_URL=http://localhost:3000

# Szerveroldali sessionök aláírására szolgáló, hosszú véletlen titok.
SESSION_SECRET=replace_with_at_least_32_random_characters

# JWT-k aláírására fenntartott, hosszú véletlen titok.
JWT_SECRET=replace_with_a_different_long_random_secret

# Auth adapter kiválasztása. Jelenleg kizárólag development támogatott.
AUTH_PROVIDER=development

# Az API belső címe és a böngészőből engedélyezett web origin.
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
PORT=3001

# UNAS integráció – üresen hagyandó, amíg nincs bekötve.
UNAS_API_KEY=
# Aktív DB credential titkosítási kulcs verziója és a hozzá tartozó pontosan
# 32 véletlen bájt base64 kódolva. Korábbi verziók rotáció alatt megőrzendők.
UNAS_CREDENTIAL_ACTIVE_KEY_VERSION=1
UNAS_CREDENTIAL_MASTER_KEY_V1=
UNAS_API_URL=https://api.unas.eu/shop
UNAS_PRODUCT_SYNC_ENABLED=false
UNAS_PRODUCT_SYNC_INTERVAL_MINUTES=15
UNAS_PRODUCT_SYNC_STARTUP_DELAY_SECONDS=30
UNAS_WEBHOOK_SECRET=

# Számlázz.hu integráció – üresen hagyandó, amíg nincs bekötve.
SZAMLAZZ_AGENT_KEY=
SZAMLAZZ_API_URL=https://www.szamlazz.hu/szamla/
SZAMLAZZ_INVOICE_PREFIX=
